  # MuJoCo simulation variant of local-qwen-voicevox-spark (g.simulation=true).
  # Robot connection is mocked (MuJoCo), but the LLM (qwen) still runs locally
  # on the Spark itself via an OpenAI-compatible server (LM Studio, vLLM, etc.),
  # so the endpoint points at localhost just like the real-hw spark profile.
  # Copy this file to .env and fill in the values.
  DIMOS_LLM_BASE_URL=http://localhost:1234/v1
  DIMOS_LLM_API_KEY=dummy
  EOF