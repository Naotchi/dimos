# DGX Spark variant of local-qwen-voicevox (real hardware, g.simulation=false).
# The LLM (qwen) runs locally on the Spark itself via an OpenAI-compatible
# server (LM Studio, vLLM, etc.), so the endpoint points at localhost rather
# than the desktop's LAN address.
# Copy this file to .env and fill in the values.
DIMOS_LLM_BASE_URL=http://localhost:1234/v1
DIMOS_LLM_API_KEY=dummy
