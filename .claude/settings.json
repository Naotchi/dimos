{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.!(example))",
      "Edit(**/.env)",
      "Edit(**/.env.!(example))",
      "Write(**/.env)",
      "Write(**/.env.!(example))",
      "Bash(cat *.env*)",
      "Bash(cat **/.env*)",
      "Bash(less *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(obsidian create *)",
      "Bash(obsidian help*)",
      "Bash(obsidian vaults)",
      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git commit *)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin refactor/*)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin refactor/*)"
    ]
  }
}
