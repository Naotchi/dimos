{
	"nodes":[
		{"id":"grp_nav","type":"group","x":420,"y":-120,"width":420,"height":920,"color":"2","label":"② Mapping & Navigation  (VoxelGridMapper = CUDA) — 矢印がデータの流れ"},
		{"id":"grp_agent","type":"group","x":1300,"y":-240,"width":440,"height":740,"color":"3","label":"④ Agent  (LLM via MCP, JA system prompt)"},
