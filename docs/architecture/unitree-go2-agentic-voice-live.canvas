		{"id":"1000000000000002","type":"text","text":"**unitree_go2_agentic_voice_live**  (autoconnect)\n\nbrain = `AzureVoiceLiveAgent` (gpt-realtime / ja-JP-NanamiNeural)  ·  system_prompt = `JAPANESE_SYSTEM_PROMPT`","x":40,"y":40,"width":1780,"height":110,"color":"6"},
		{"id":"1000000000000003","type":"text","text":"**unitree_go2_spatial**\n\nロボット基盤 + 知覚 + 地図","x":40,"y":180,"width":340,"height":150,"color":"5"},
